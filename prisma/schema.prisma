generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CatalogItem {
  id              String      @id @default(uuid())
  name            String
  coverImage      String?     @db.Text
  carouselImages  String[]    
  ingredients     String[]
  price           Float
  promos          Json?
  orderItems      OrderItem[]
}

model Order {
  id                String      @id @default(uuid())
  customerName      String
  phone             String?
  address           String?
  notes             String?
  delivery          Boolean     @default(false)
  deliveryCost      Float       @default(0)
  date              DateTime    @default(now())
  paymentMethod     String      @default("Efectivo")
  status            String      @default("Pendiente")
  paymentStatus     String      @default("Pendiente de pago")
  total             Float
  items             OrderItem[]
  createdById       String?
  createdByUsername String?
  history           OrderStatusHistory[]
}

model OrderItem {
  id            String      @id @default(uuid())
  orderId       String
  catalogId     String
  quantity      Int
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  catalogItem   CatalogItem @relation(fields: [catalogId], references: [id], onDelete: Restrict)
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  userId    String?
  username  String?
  date      DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StockItem {
  id          String          @id @default(uuid())
  name        String
  quantity    Float
  unit        String
  minQuantity Float
  finances    FinanceRecord[]
  recipeIngredients RecipeIngredient[]
}

model FinanceRecord {
  id            String    @id @default(uuid())
  date          DateTime  @default(now())
  ingredientId  String
  quantityAdded Float
  totalCost     Float
  stockItem     StockItem @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
}

model Customer {
  id          String   @id @default(uuid())
  name        String
  phone       String?  @unique
  ordersCount Int      @default(0)
  createdAt   DateTime @default(now())
}

model Recipe {
  id          String   @id @default(uuid())
  name        String
  preparation String   @db.Text
  ingredients RecipeIngredient[]
  createdAt   DateTime @default(now())
}

model RecipeIngredient {
  id          String   @id @default(uuid())
  recipeId    String
  stockItemId String
  quantity    Float
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Restrict)
}
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("user") // "admin" or "user"
  createdAt DateTime @default(now())
}

model StockRevision {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  details   Json     // List of items and their values at revision time
  notes     String?
  userId    String?
  username  String?
}
